{
  "name": "rscute",
  "version": "3.1.1",
  "description": "SWC-powered TypeScript JIT runner for Node.js",
  "keywords": [
    "swc",
    "executor",
    "typescript",
    "cli",
    "runtime",
    "node",
    "cjs",
    "esm"
  ],
  "author": "Refirst 11",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/refirst11/rscute.git"
  },
  "bugs": {
    "url": "https://github.com/refirst11/rscute/issues"
  },
  "license": "MIT",
  "exports": {
    "./register": {
      "import": "./dist/register.js",
      "require": "./dist/register.js",
      "types": "./dist/register.d.ts"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "rscute": "./dist/cli.js"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "rimraf dist && tsc && chmod +x dist/cli.js",
    "test": "node integration_test.js"
  },
  "dependencies": {
    "@swc/core": "1.15.43",
    "get-tsconfig": "^4.14.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=20.6.0"
  }
}
